<div class="header-section">
  <h2>📊 לוח בקרה</h2>
  <p>סקירת מצב החנות</p>
</div>

<div class="stats">
  <div class="stat"><h3>מוצרים</h3><p><%= products.length %></p></div>
  <div class="stat"><h3>הזמנות</h3><p><%= orders.length %></p></div>
  <div class="stat"><h3>לקוחות</h3><p><%= customers.length %></p></div>
  <div class="stat"><h3>ממתינות</h3><p><%= orders.filter(o => o.status === 'pending').length %></p></div>
</div>

<div class="card">
  <h3 style="margin-bottom:16px;font-size:16px;font-weight:700">📋 הזמנות אחרונות</h3>
  <div class="table-wrap">
    <table>
      <thead><tr><th>הזמנה</th><th>לקוח</th><th>סה"כ</th><th>סטטוס</th><th>תאריך</th></tr></thead>
      <tbody>
        <% orders.slice(0, 10).forEach(o => { %>
        <tr>
          <td><a href="/api/orders/<%= o.id %>"><%= o.id.slice(0,8) %>...</a></td>
          <td><%= o.customer_phone %></td>
          <td>₪<%= o.total.toFixed(2) %></td>
          <td><span class="badge badge-<%= o.status %>"><%= {pending:'ממתינה',confirmed:'אושרה',preparing:'בהכנה',out_for_delivery:'בדרך',delivered:'נמסרה',cancelled:'בוטלה'}[o.status] || o.status %></span></td>
          <td><%= new Date(o.created_at).toLocaleDateString('he-IL') %></td>
        </tr>
        <% }) %>
        <% if (orders.length === 0) { %><tr><td colspan="5" style="text-align:center;color:var(--text-muted);padding:40px">אין הזמנות</td></tr><% } %>
      </tbody>
    </table>
  </div>
</div>
